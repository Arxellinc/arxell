#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Prefer prebuilt/local binaries first.
for candidate in \
  "${ROOT_DIR}/codex" \
  "${ROOT_DIR}/codex-rs/target/release/codex" \
  "${ROOT_DIR}/codex-rs/target/debug/codex"
do
  if [ -x "${candidate}" ] && [ "${candidate}" != "${BASH_SOURCE[0]}" ]; then
    exec "${candidate}" "$@"
  fi
done

# In isolated app mode, never delegate to any globally installed Codex binary.
if [ "${ARX_CODER_ISOLATED:-0}" != "1" ]; then
  # Fall back to a globally installed Codex binary if it isn't this launcher.
  if command -v codex >/dev/null 2>&1; then
    GLOBAL_CODEX="$(command -v codex || true)"
    if [ -n "${GLOBAL_CODEX}" ] && [ "${GLOBAL_CODEX}" != "${BASH_SOURCE[0]}" ]; then
      exec "${GLOBAL_CODEX}" "$@"
    fi
  fi
fi

# Last resort for source-only checkouts: run the Rust CLI from this repo.
if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --manifest-path "${ROOT_DIR}/codex-rs/Cargo.toml" -p codex-cli -- "$@"
fi

echo "No Codex executable found." >&2
echo "Install codex, or build src-tauri/resources/coder/codex-main/codex-rs first." >&2
exit 127
