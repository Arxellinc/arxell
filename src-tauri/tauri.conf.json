{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arxell",
  "version": "0.9.6",
  "identifier": "dev.arx.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Arxell",
        "width": 1920,
        "height": 1080,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/silero_vad.onnx": "resources/silero_vad.onnx",
      "resources/scripts/voice/tts_kokoro.py": "resources/scripts/voice/tts_kokoro.py",
      "resources/scripts/voice/tts_kokoro_persistent.py": "resources/scripts/voice/tts_kokoro_persistent.py",
      "resources/scripts/voice/stt_whisper.py": "resources/scripts/voice/stt_whisper.py",
      "resources/scripts/voice/stt_whisper_persistent.py": "resources/scripts/voice/stt_whisper_persistent.py",
      "resources/kokoro-runtime": "resources/kokoro-runtime",
      "../public/whisper/ggml-base-q8_0.bin": "resources/whisper/ggml-base-q8_0.bin",
      "../public/whisper/ggml-tiny.en-q8_0.bin": "resources/whisper/ggml-tiny.en-q8_0.bin",
      "../public/voice": "resources/voice"
    }
  }
}
