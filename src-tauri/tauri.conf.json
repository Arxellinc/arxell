{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arxell",
  "version": "0.2.7",
  "identifier": "com.arxell.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm --prefix frontend run dev -- --host 127.0.0.1 --port 5173 --strictPort",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "Arxell",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src 'self' mediastream:; connect-src ipc: http://127.0.0.1"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "msi",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "useLocalToolsDir": false,
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
