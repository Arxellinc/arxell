{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vite/client"],
    "rootDir": ".",
    "outDir": ".tmp-tests",
    "noEmit": false
  },
  "include": [
    "src/tts/**/*.ts",
    "src/app/chatSend.ts",
    "src/app/sendMessageBootstrap.ts",
    "src/contracts.ts",
    "src/tools/sheets/actions.ts",
    "src/tools/sheets/gridMapping.ts",
    "src/tools/sheets/state.ts",
    "src/tools/looper/state.ts",
    "src/tools/looper/runtime.ts",
    "tests/**/*.ts"
  ]
}
