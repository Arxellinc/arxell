{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": ".",
    "outDir": ".tmp-tests",
    "noEmit": false
  },
  "include": [
    "src/tts/**/*.ts",
